#!/bin/bash

# bundleit – bundle files/dirs per .bundleit spec, then optionally archive as EPUB or ZIP.

set -euo pipefail

# ── Constants ─────────────────────────────────────────────────────────────────
readonly BUNDLEIT_FILE=".bundleit"
readonly EPUB_MIMETYPE="application/epub+zip"
readonly SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly BUNDLEIT_EXAMPLE_TEMPLATE="$SCRIPT_DIR/templates/.bundleit_example"

# ── I/O helpers ───────────────────────────────────────────────────────────────
info() { echo "  $1"; }
ok()   { echo "✔️  $1"; }
err()  { echo "❌ Error: $1" >&2; exit 1; }

# ask_yn "Prompt text" [Y|N(default)]  →  echoes the answer character
ask_yn() {
    local prompt="$1" default="${2:-N}"
    local hint
    [[ "$default" == [Yy] ]] && hint="Y/n" || hint="y/N"
    local reply
    read -rp "${prompt} (${hint}, default: ${default}): " reply
    echo "${reply:-$default}"
}

# ── Environment validation ────────────────────────────────────────────────────
validate_environment() {
    if [[ ! -f "$BUNDLEIT_FILE" ]]; then
        echo "No .bundleit file found in the current directory."
        local choice
        choice=$(ask_yn "Create a .bundleit example file here for reference?" "N")
        if [[ "$choice" =~ ^[Yy]$ ]]; then
            if [[ ! -f "$BUNDLEIT_EXAMPLE_TEMPLATE" ]]; then
                err "Example template not found at: $BUNDLEIT_EXAMPLE_TEMPLATE"
            fi
            cp "$BUNDLEIT_EXAMPLE_TEMPLATE" ".bundleit"
            ok ".bundleit created. Edit it and include files and folders get started."
        fi
        exit 1
    fi
    ok ".bundleit found."
}

# ── Build directory ───────────────────────────────────────────────────────────
init_build_dir() {
    build_dir="${1:-$(basename "$PWD")}"
    [[ -d "$build_dir" ]] && { info "Cleaning existing '$build_dir/'..."; rm -rf "$build_dir"; }
    mkdir -p "$build_dir"
}

# ── File collection ───────────────────────────────────────────────────────────
parse_bundleit() {
    include_patterns=()
    exclude_patterns=()
    while IFS= read -r line; do
        [[ -z "$line" || "$line" =~ ^# ]] && continue
        if [[ "$line" == '!'* ]]; then
            exclude_patterns+=("${line:1}")
        else
            include_patterns+=("$line")
        fi
    done < "$BUNDLEIT_FILE"
}

copy_included_files() {
    for pat in "${include_patterns[@]}"; do
        info "Adding: $pat"
        local rsynced="$pat"
        [[ "$rsynced" == */* ]] && rsynced="${rsynced%/*}/"
        if [[ -d "$rsynced" || "$rsynced" == */ ]]; then
            rsync -a --include="*/*" --include="$rsynced" --exclude="*" ./ "$build_dir/"
        else
            rsync -a --include="$rsynced" --exclude="*" ./ "$build_dir/"
        fi
    done
}

apply_exclusions() {
    for pat in "${exclude_patterns[@]}"; do
        info "Excluding: $pat"
        find "$build_dir" -type f -path "$build_dir/$pat" -exec rm -f {} \;
    done
}

bundle_files() {
    parse_bundleit
    copy_included_files
    apply_exclusions
    ok "Bundled into '$build_dir/'."
}

# ── Mimetype resolution ───────────────────────────────────────────────────────

# Returns 0 if 'mimetype' is listed as an include entry in .bundleit
mimetype_in_bundleit() {
    grep -qxF "mimetype" "$BUNDLEIT_FILE"
}

# Sets MIMETYPE_CONTENT: prompts user if a mimetype file exists in project root
resolve_mimetype() {
    if mimetype_in_bundleit && [[ -f "mimetype" ]]; then
        local existing
        existing=$(<mimetype)
        local choice
        choice=$(ask_yn "mimetype found in project ('$existing'). Use existing?" "Y")
        if [[ "$choice" =~ ^[Yy]$ ]]; then
            MIMETYPE_CONTENT="$existing"
            info "Using existing mimetype: $MIMETYPE_CONTENT"
            return
        fi
    fi
    MIMETYPE_CONTENT="$EPUB_MIMETYPE"
    info "Using standard EPUB mimetype: $EPUB_MIMETYPE"
}

# ── EPUB creation ─────────────────────────────────────────────────────────────
create_epub() {
    local output="$(pwd)/${build_dir}.epub"
    [[ -f "$output" ]] && { info "Removing old '${build_dir}.epub'..."; rm -f "$output"; }

    resolve_mimetype

    info "Building EPUB '${build_dir}.epub'..."
    (
        cd "$build_dir"
        # Write mimetype with no trailing newline (required by EPUB spec)
        printf '%s' "$MIMETYPE_CONTENT" > mimetype
        # Step 1: mimetype must be first, store-only (-0), no ZIP extra fields (-X)
        zip -X -0 "$output" mimetype
        # Step 2: all remaining files, excluding mimetype
        zip -rg "$output" . --exclude ./mimetype
        rm -f mimetype
    )
    ok "EPUB created: '${build_dir}.epub'"
}

# ── ZIP creation ──────────────────────────────────────────────────────────────
create_zip_from_build() {
    local output="$(pwd)/${build_dir}.zip"
    [[ -f "$output" ]] && { info "Removing old '${build_dir}.zip'..."; rm -f "$output"; }
    info "Creating ZIP '${build_dir}.zip'..."
    (cd "$build_dir" && zip -r "$output" .)
    ok "ZIP created: '${build_dir}.zip'"
}

create_zip_from_epub() {
    local epub="$(pwd)/${build_dir}.epub"
    local output="$(pwd)/${build_dir}.zip"
    [[ -f "$output" ]] && { info "Removing old '${build_dir}.zip'..."; rm -f "$output"; }
    cp "$epub" "$output"
    ok "ZIP created from EPUB: '${build_dir}.zip'"
}

# ── Build dir cleanup ─────────────────────────────────────────────────────────
maybe_remove_build_dir() {
    local choice
    choice=$(ask_yn "Remove '$build_dir/' directory?" "Y")
    if [[ "$choice" =~ ^[Yy]$ ]]; then
        rm -rf "$build_dir"
        info "'$build_dir/' removed."
    fi
}

# ── Archive dispatch ──────────────────────────────────────────────────────────
prompt_and_create_archive() {
    local epub_choice
    epub_choice=$(ask_yn "Create EPUB?" "N")

    if [[ "$epub_choice" =~ ^[Yy]$ ]]; then
        create_epub
        local zip_choice
        zip_choice=$(ask_yn "Also create ZIP?" "N")
        [[ "$zip_choice" =~ ^[Yy]$ ]] && create_zip_from_epub
        maybe_remove_build_dir
        return
    fi

    local zip_choice
    zip_choice=$(ask_yn "Create ZIP?" "N")
    if [[ "$zip_choice" =~ ^[Yy]$ ]]; then
        create_zip_from_build
        maybe_remove_build_dir
    else
        info "Bundle available in '$build_dir/'."
    fi
}

# ── Help ──────────────────────────────────────────────────────────────────────
show_help() {
    cat <<EOF
Usage: $(basename "$0") [build_dir|--help]

Bundles files listed in .bundleit into a directory, then optionally creates an EPUB or ZIP.

.bundleit format:
  mimetype             include mimetype file (handled specially for EPUB)
  folder/              include directory and contents
  *.ext                include files matching glob
  !excluded.txt        exclude pattern

Archive options (prompted interactively):
  EPUB  – proper EPUB: mimetype first, uncompressed, no ZIP extra fields
  ZIP   – standard ZIP of bundle contents (or copy of EPUB if created first)

Options:
  build_dir   Output directory name (default: current directory name)
  --help      Show this help
EOF
    exit 0
}

# ── Entry point ───────────────────────────────────────────────────────────────
main() {
    [[ "${1:-}" == "--help" ]] && show_help

    validate_environment
    echo "Bundling..."
    init_build_dir "${1:-}"
    bundle_files
    prompt_and_create_archive

    echo ""
    ok "All tasks completed."
}

main "$@"
